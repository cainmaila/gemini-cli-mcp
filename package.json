{
  "name": "@cainmaila/gemini-cli-mcp",
  "version": "1.0.0",
  "description": "MCP server that delegates prompt execution to a locally installed Gemini CLI",
  "type": "module",
  "bin": {
    "gemini-cli-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gemini",
    "gemini-cli",
    "ai",
    "llm",
    "claude",
    "ai-delegation"
  ],
  "author": {
    "name": "cain.chu",
    "email": "cain.chu@dgiots.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cainmaila/gemini-cli-mcp.git"
  },
  "homepage": "https://github.com/cainmaila/gemini-cli-mcp#readme",
  "bugs": {
    "url": "https://github.com/cainmaila/gemini-cli-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
